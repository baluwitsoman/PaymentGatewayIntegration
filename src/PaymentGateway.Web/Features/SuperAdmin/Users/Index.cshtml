@page
@model PaymentGateway.Web.Features.SuperAdmin.Users.IndexModel
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0"><i class="bi bi-people"></i> Users</h3>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead class="table-light small text-uppercase">
                        <tr>
                            <th>Email</th>
                            <th>Name</th>
                            <th>Role</th>
                            <th>Company</th>
                            <th>Status</th>
                            <th>Last login</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model.Items)
                        {
                            <tr>
                                <td>@u.Email</td>
                                <td>@u.FullName</td>
                                <td><span class="badge bg-secondary-subtle text-dark">@u.Role</span></td>
                                <td class="text-muted small">@u.Company</td>
                                <td>
                                    @if (u.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">Disabled</span>
                                    }
                                </td>
                                <td class="text-muted small">@(u.LastLoginAt?.ToString("yyyy-MM-dd HH:mm"))</td>
                                <td class="text-end">
                                    <form method="post" asp-page-handler="Toggle" asp-route-userId="@u.Id" class="d-inline">
                                        <button class="btn btn-sm btn-outline-secondary"><i class="bi bi-power"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h6 class="mb-3">Add user</h6>
                <form method="post" asp-page-handler="Add">
                    <div class="mb-2">
                        <label class="form-label small fw-semibold">Email</label>
                        <input asp-for="New.Email" class="form-control" />
                        <span asp-validation-for="New.Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small fw-semibold">Full name</label>
                        <input asp-for="New.FullName" class="form-control" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small fw-semibold">Role</label>
                        <select asp-for="New.Role" asp-items="Html.GetEnumSelectList<PaymentGateway.Web.Domain.Enums.UserRole>()" class="form-select"></select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small fw-semibold">Company (required for non-super-admin)</label>
                        <select asp-for="New.CompanyId" class="form-select">
                            <option value="">— select company —</option>
                            @foreach (var c in Model.Companies)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Initial password</label>
                        <input asp-for="New.Password" type="password" class="form-control" />
                        <span asp-validation-for="New.Password" class="text-danger small"></span>
                    </div>
                    <button class="btn btn-primary w-100">Add user</button>
                </form>
            </div>
        </div>
    </div>
</div>
