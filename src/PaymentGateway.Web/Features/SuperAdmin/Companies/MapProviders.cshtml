@page "{id:guid}"
@model PaymentGateway.Web.Features.SuperAdmin.Companies.MapProvidersModel
@{
    ViewData["Title"] = "Map providers";
}

<div class="d-flex align-items-center mb-3">
    <a asp-page="Providers" asp-route-id="@Model.Id" class="btn btn-link text-decoration-none px-0 me-2"><i class="bi bi-arrow-left"></i></a>
    <h3 class="mb-0">Map providers — @Model.CompanyName</h3>
</div>

<p class="text-muted small">
    Choose which providers this company may use. Only enabled catalog providers are listed.
    Mapped providers appear on the company's <a asp-page="Providers" asp-route-id="@Model.Id">Providers</a> screen for credential entry.
    Unchecking a provider hides it from that configuration screen without deleting saved credentials.
    To also stop it appearing at customer checkout, deactivate the provider on its credentials screen.
</p>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form method="post">
            <input type="hidden" asp-for="Id" />
            @if (!Model.Rows.Any())
            {
                <div class="alert alert-info mb-0">No enabled providers in the catalog. Enable one under <a asp-page="/SuperAdmin/Providers/Index">Provider catalog</a> first.</div>
            }
            else
            {
                <div class="list-group mb-4">
                    @foreach (var r in Model.Rows)
                    {
                        <label class="list-group-item d-flex align-items-center gap-3">
                            <input class="form-check-input m-0" type="checkbox" name="Selected" value="@((short)r.Code)" checked="@r.Mapped" />
                            <span class="fw-semibold">@r.DisplayName</span>
                            <span class="text-muted small">code: @((short)r.Code)</span>
                            @if (r.Configured)
                            {
                                <span class="badge bg-success-subtle text-success ms-auto">Has credentials</span>
                            }
                        </label>
                    }
                </div>
                <button class="btn btn-primary" type="submit">Save mapping</button>
                <a class="btn btn-link" asp-page="Providers" asp-route-id="@Model.Id">Cancel</a>
            }
        </form>
    </div>
</div>
