@page "{code}"
@model PaymentGateway.Web.Features.SuperAdmin.Providers.EditModel
@{
    ViewData["Title"] = $"Edit {Model.DisplayName}";
}

<div class="d-flex align-items-center mb-3">
    <a asp-page="Index" class="btn btn-link text-decoration-none px-0 me-2"><i class="bi bi-arrow-left"></i></a>
    <h3 class="mb-0">Edit provider — @Model.DisplayName</h3>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
                <form method="post">
                    <input type="hidden" asp-for="Code" />
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label small fw-semibold">Display name</label>
                            <input asp-for="DisplayName" class="form-control" />
                            <span asp-validation-for="DisplayName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Sort order</label>
                            <input asp-for="SortOrder" type="number" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-semibold">Default base URL</label>
                            <input asp-for="DefaultBaseUrl" class="form-control" placeholder="pre-filled when a company first configures this provider" />
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-semibold">Example provider-specific config (JSON)</label>
                            <textarea asp-for="ExampleExtraConfigJson" class="form-control font-monospace" rows="3"></textarea>
                            <span asp-validation-for="ExampleExtraConfigJson" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input asp-for="IsEnabled" class="form-check-input" />
                                <label class="form-check-label" asp-for="IsEnabled">Enabled (available for mapping to companies)</label>
                            </div>
                        </div>
                    </div>
                    <div class="mt-4">
                        <button class="btn btn-primary" type="submit">Save</button>
                        <a class="btn btn-link" asp-page="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
