@page "{id:guid}"
@model PaymentGateway.Web.Features.Company.Applications.KeysModel
@{
    ViewData["Title"] = "API keys";
    var newKey = TempData["NewKey"] as string;
}

<div class="d-flex align-items-center mb-3">
    <a asp-page="Index" class="btn btn-link text-decoration-none px-0 me-2"><i class="bi bi-arrow-left"></i></a>
    <h3 class="mb-0">API keys — @Model.App.Name</h3>
</div>

@if (!string.IsNullOrEmpty(newKey))
{
    <div class="alert alert-warning shadow-sm">
        <h6 class="alert-heading"><i class="bi bi-exclamation-triangle"></i> Copy this key now — it won't be shown again.</h6>
        <code class="user-select-all d-block p-2 bg-light rounded mt-2">@newKey</code>
    </div>
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead class="table-light small text-uppercase">
                        <tr>
                            <th>Prefix</th>
                            <th>Label</th>
                            <th>Created</th>
                            <th>Last used</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var k in Model.App.ApiKeys.OrderByDescending(k => k.CreatedAt))
                        {
                            <tr>
                                <td><code>@k.KeyPrefix…</code></td>
                                <td>@k.Label</td>
                                <td class="text-muted small">@k.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td class="text-muted small">@(k.LastUsedAt?.ToString("yyyy-MM-dd HH:mm"))</td>
                                <td>
                                    @if (k.RevokedAt != null) { <span class="badge bg-danger-subtle text-danger">Revoked</span> }
                                    else if (k.IsActive) { <span class="badge bg-success-subtle text-success">Active</span> }
                                    else { <span class="badge bg-secondary-subtle text-secondary">Disabled</span> }
                                </td>
                                <td class="text-end">
                                    @if (k.RevokedAt == null)
                                    {
                                        <form method="post" asp-page-handler="Revoke" asp-route-keyId="@k.Id" class="d-inline" onsubmit="return confirm('Revoke this key? Applications using it will stop working.')">
                                            <button class="btn btn-sm btn-outline-danger">Revoke</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.App.ApiKeys.Any())
                        {
                            <tr><td colspan="6" class="text-center text-muted py-4">No keys generated yet.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h6>Generate new key</h6>
                <p class="small text-muted">The key will be displayed once. Store it securely in your application's configuration.</p>
                <form method="post" asp-page-handler="Generate">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Label (optional)</label>
                        <input asp-for="Label" class="form-control" placeholder="production / rotation-may-2026" />
                    </div>
                    <button class="btn btn-primary w-100">Generate API key</button>
                </form>
            </div>
        </div>
    </div>
</div>
