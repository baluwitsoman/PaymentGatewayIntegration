@page
@model PaymentGateway.Web.Features.Company.Payments.IndexModel
@{
    ViewData["Title"] = "Payments";
    var totalPages = (int)Math.Ceiling((double)Model.Total / Model.PageSize);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0"><i class="bi bi-receipt"></i> Payments</h3>
</div>

<form method="get" class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Search</label>
                <input class="form-control" name="q" value="@Model.Query" placeholder="Reference / customer / ext ref" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Status</label>
                <select name="status" class="form-select" asp-items="Html.GetEnumSelectList<PaymentGateway.Web.Domain.Enums.PaymentOrderStatus>()">
                    <option value="">All</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">From</label>
                <input type="date" name="from" value="@Model.From?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">To</label>
                <input type="date" name="to" value="@Model.To?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-primary w-100" type="submit"><i class="bi bi-funnel"></i> Filter</button>
            </div>
        </div>
    </div>
</form>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light small text-uppercase">
                <tr>
                    <th>Reference</th>
                    <th>Customer</th>
                    <th>External ref</th>
                    <th>App</th>
                    <th class="text-end">Amount</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Paid</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Items)
                {
                    <tr>
                        <td><code>@p.Reference</code></td>
                        <td>
                            <div class="fw-semibold">@p.CustomerName</div>
                            <div class="text-muted small">@p.CustomerCode</div>
                        </td>
                        <td class="text-muted small">@p.ExternalReference</td>
                        <td class="text-muted small">@p.AppName</td>
                        <td class="text-end fw-semibold">@((p.AmountMinor / 100m).ToString("N2")) @p.Currency</td>
                        <td>
                            @switch (p.Status)
                            {
                                case "Paid": <span class="badge bg-success-subtle text-success">Paid</span> break;
                                case "Failed": <span class="badge bg-danger-subtle text-danger">Failed</span> break;
                                case "AwaitingPayment": <span class="badge bg-warning-subtle text-warning">Awaiting</span> break;
                                case "Created": <span class="badge bg-secondary-subtle text-secondary">Created</span> break;
                                case "Cancelled": <span class="badge bg-secondary-subtle text-secondary">Cancelled</span> break;
                                case "Expired": <span class="badge bg-secondary-subtle text-secondary">Expired</span> break;
                            }
                        </td>
                        <td class="text-muted small">@p.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-muted small">@(p.PaidAt?.ToString("yyyy-MM-dd HH:mm"))</td>
                        <td><a class="btn btn-sm btn-outline-secondary" asp-page="Detail" asp-route-id="@p.Id"><i class="bi bi-eye"></i></a></td>
                    </tr>
                }
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="9" class="text-center text-muted py-4">No payments match.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm">
            @for (var i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link"
                       asp-route-page="@i" asp-route-q="@Model.Query"
                       asp-route-status="@Model.Status" asp-route-from="@Model.From?.ToString("yyyy-MM-dd")"
                       asp-route-to="@Model.To?.ToString("yyyy-MM-dd")">@i</a>
                </li>
            }
        </ul>
    </nav>
}
