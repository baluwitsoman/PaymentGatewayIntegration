@using System.Security.Claims
@{
    var role = User.FindFirstValue(PaymentGateway.Web.Infrastructure.Multitenancy.CurrentUser.ClaimRole);
    var isSuper = role == "1";
    var isCompany = role == "2" || role == "3";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Payment Gateway</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-0 shadow-sm">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-semibold" asp-page="/Index">
                <i class="bi bi-credit-card-2-front"></i> Payment Gateway
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto">
                    @if (isSuper)
                    {
                        <li class="nav-item"><a class="nav-link" asp-page="/SuperAdmin/Companies/Index"><i class="bi bi-building"></i> Companies</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/SuperAdmin/Users/Index"><i class="bi bi-people"></i> Users</a></li>
                    }
                    @if (isCompany)
                    {
                        <li class="nav-item"><a class="nav-link" asp-page="/Company/Dashboard/Index"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Company/Customers/Index"><i class="bi bi-person"></i> Customers</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Company/Payments/Index"><i class="bi bi-receipt"></i> Payments</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Company/Applications/Index"><i class="bi bi-app"></i> Applications</a></li>
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">
                                <i class="bi bi-person-circle"></i> @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><form asp-page="/Auth/Logout" method="post"><button class="dropdown-item" type="submit">Sign out</button></form></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-page="/Auth/Login">Sign in</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="container-fluid px-4 py-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </main>

    <footer class="border-top text-muted py-3 mt-5">
        <div class="container-fluid px-4 small">
            &copy; @DateTime.UtcNow.Year — Payment Gateway
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
