@page "/pay/return"
@model PaymentGateway.Web.Features.PublicApi.Redirect.PaymobReturnModel
@{
    Layout = null;
    ViewData["Title"] = "Processing payment";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    @if (!string.IsNullOrEmpty(Model.RedirectTo))
    {
        <meta http-equiv="refresh" content="1;url=@Model.RedirectTo" />
    }
    <style>
        body { background: #f1f5f9; min-height: 100vh; }
        .verify-card { max-width: 480px; margin: 10vh auto; }
    </style>
</head>
<body>
    <div class="container">
        <div class="card verify-card shadow-sm border-0">
            <div class="card-body p-5 text-center">
                @if (Model.Status == "verifying")
                {
                    <div class="spinner-border text-primary mb-3" role="status"></div>
                    <h5>Verifying your payment&hellip;</h5>
                    <p class="text-muted small">This usually takes just a moment. Please don't close this window.</p>
                    <script>setTimeout(() => location.reload(), 3000);</script>
                }
                else if (Model.Status == "paid")
                {
                    <div class="display-1 text-success">&#10004;</div>
                    <h4 class="text-success">Payment successful</h4>
                    <p class="text-muted small">Returning you to the application&hellip;</p>
                }
                else
                {
                    <div class="display-1 text-danger">&#10006;</div>
                    <h4 class="text-danger">Payment @Model.Status</h4>
                    <p class="text-muted small">Returning you to the application&hellip;</p>
                }
            </div>
        </div>
    </div>
</body>
</html>
