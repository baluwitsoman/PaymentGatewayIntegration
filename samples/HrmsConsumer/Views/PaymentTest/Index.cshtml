@*  File: Views/PaymentTest/Index.cshtml  *@
@model YourHrms.Controllers.PayFormModel
@{
    ViewData["Title"] = "Test Payment";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h4 class="mb-1"><i class="bi bi-credit-card"></i> Initiate a payment</h4>
                    <p class="text-muted small">This test posts to the Payment Gateway orchestrator and redirects you to the secure payment page.</p>

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                    <form asp-action="Index" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label asp-for="EmployeeId" class="form-label small fw-semibold">Employee ID</label>
                                <input asp-for="EmployeeId" class="form-control" placeholder="EMP-1042" />
                                <span asp-validation-for="EmployeeId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-8">
                                <label asp-for="EmployeeName" class="form-label small fw-semibold">Employee name</label>
                                <input asp-for="EmployeeName" class="form-control" placeholder="Ahmed Hassan" />
                                <span asp-validation-for="EmployeeName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Mobile" class="form-label small fw-semibold">Mobile</label>
                                <input asp-for="Mobile" class="form-control" placeholder="+201001234567" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label small fw-semibold">Email</label>
                                <input asp-for="Email" class="form-control" placeholder="ahmed@example.com" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="AmountEgp" class="form-label small fw-semibold">Amount (EGP)</label>
                                <div class="input-group">
                                    <input asp-for="AmountEgp" type="number" step="0.01" min="1" class="form-control" />
                                    <span class="input-group-text">EGP</span>
                                </div>
                                <span asp-validation-for="AmountEgp" class="text-danger small"></span>
                            </div>
                            <div class="col-md-8">
                                <label asp-for="Description" class="form-label small fw-semibold">Description (optional)</label>
                                <input asp-for="Description" class="form-control" placeholder="Salary advance — Jan 2026" />
                            </div>
                        </div>

                        <hr class="my-4" />
                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            <i class="bi bi-arrow-right-circle"></i> Pay now
                        </button>
                        <p class="text-muted small text-center mt-2 mb-0">You'll be redirected to the secure payment page.</p>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
